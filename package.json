{
  "name": "prove-present",
  "version": "3.0.0",
  "description": "ProvePresent - Peer-verified classroom attendance with chain technology and AI-powered engagement",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "install:all": "npm install && npm install --prefix frontend && npm install --prefix backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "cd backend && npm run start",
    "build:frontend": "npm run build --workspace=frontend",
    "build:backend": "cd backend && npm run build",
    "test": "npm run test --workspaces && cd backend && npm test",
    "test:unit": "npm run test:unit --workspaces && cd backend && npm run test:unit",
    "test:property": "npm run test:property --workspaces && cd backend && npm run test:property",
    "lint": "npm run lint --workspaces && cd backend && npm run lint",
    "create-agents": "tsx create-agents.ts"
  },
  "devDependencies": {
    "@azure/ai-projects": "^2.0.0-beta.5",
    "@azure/identity": "^4.5.0",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@typescript-eslint/type-utils": "^8.56.1",
    "@typescript-eslint/typescript-estree": "^8.56.1",
    "@typescript-eslint/utils": "^8.56.1",
    "ajv": "^6.14.0",
    "minimatch": "^9.0.6",
    "rollup": "^2.80.0",
    "eslint-config-next": {
      "@typescript-eslint/eslint-plugin": "^8.56.1",
      "@typescript-eslint/parser": "^8.56.1",
      "@typescript-eslint/type-utils": "^8.56.1",
      "@typescript-eslint/typescript-estree": "^8.56.1",
      "@typescript-eslint/utils": "^8.56.1"
    }
  },
  "keywords": [
    "attendance",
    "qr-code",
    "azure",
    "anti-cheat",
    "education"
  ],
  "author": "",
  "license": "MIT"
}
